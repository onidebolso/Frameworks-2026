---
interface Props {
  posts: any[];
}

const { posts } = Astro.props as Props;
---

<div class="mb-4">
  <input
    type="text"
    id="search"
    placeholder="Buscar artigos..."
    class="w-full p-2 border border-gray-300 rounded"
  />
  <ul id="results" class="mt-2 space-y-1 hidden"></ul>
</div>

<script define:vars={{ posts: posts.map(p => ({ slug: Array.isArray(p.slug) ? p.slug.join('/') : p.slug, title: p.data.title })) }}>
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const resultsList = document.getElementById('results') as HTMLUListElement;

  searchInput.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    const filtered = posts.filter((post: any) =>
      post.title.toLowerCase().includes(query)
    );
    resultsList.innerHTML = filtered
      .map((post: any) => `<li><a href="/wiki/${post.slug}" class="text-blue-600 hover:underline">${post.title}</a></li>`)
      .join('');
    resultsList.classList.toggle('hidden', filtered.length === 0);
  });
</script>