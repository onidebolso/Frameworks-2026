---
import Layout from '../layouts/Layout.astro';
import ExpandableIsland from '../components/ExpandableIsland.jsx';
import { getCollection } from 'astro:content';

const buttonOrder = [
  'base-do-jogo',
  'ideia',
  'bts',
  'mundo',
  'bebes-bbs',
  'trilha-sonora',
  'multijogador',
  'entregas',
] as const;

const wikiItems = await getCollection('wiki');
const sections = buttonOrder
  .map((slug) => wikiItems.find((item) => item.id === slug))
  .filter((item): item is (typeof wikiItems)[number] => Boolean(item));
---

<Layout>
	<main>
		<h1>Death Stranding</h1>
		<ExpandableIsland sections={sections} client:load />
	</main>

<div class="floating-island">
<button class="info-button" title="Informações">
<span class="icon">ℹ</span>
</button>
<div class="dialog-box">
<p>Bem-vindo Death Stranding.</p>
</div>
</div>
</Layout>
