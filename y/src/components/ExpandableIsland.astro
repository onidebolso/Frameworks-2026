---
type SectionSlug =
  | 'base-do-jogo'
  | 'ideia'
  | 'bts'
  | 'mundo'
  | 'bebes-bbs'
  | 'trilha-sonora'
  | 'multijogador'
  | 'entregas';

type WikiSection = {
  id: SectionSlug;
  collection: 'wiki';
  data: {
    title: string;
    summary: string;
    details: Array<{ heading: string; text: string }>;
  };
};

const { sections } = Astro.props as { sections: WikiSection[] };
const iconMap: Record<SectionSlug, string> = {
  'base-do-jogo': 'ᖭ༏ᖫ',
  ideia: '📖',
  bts: '💀',
  mundo: '🌍',
  'bebes-bbs': '👶',
  'trilha-sonora': '🎵',
  multijogador: '🌐',
  entregas: '📦',
};
const leftButtons = sections.slice(0, 4);
const rightButtons = sections.slice(4);
---

<div class="content-with-buttons interactive-island">
  <div class="side-buttons left-buttons">
    {leftButtons.map((section) => (
      <div class="floating-button-group">
        <button
          class="side-button"
          type="button"
          aria-label={section.data.title}
          aria-expanded="false"
          aria-controls={`${section.id}-panel`}
          data-section={section.id}
        >
          <span class="icon">{iconMap[section.id] ?? '•'}</span>
        </button>
        <div id={`${section.id}-panel`} class="side-dialog" hidden>
          <h4>{section.data.title}</h4>
          <p>{section.data.summary}</p>
          {section.data.details.map((item) => (
            <div>
              <h4>{item.heading}</h4>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <img src="/SAM1.gif" alt="Sam" class="sam-gif" />

  <div class="side-buttons right-buttons">
    {rightButtons.map((section) => (
      <div class="floating-button-group">
        <button
          class="side-button"
          type="button"
          aria-label={section.data.title}
          aria-expanded="false"
          aria-controls={`${section.id}-panel`}
          data-section={section.id}
        >
          <span class="icon">{iconMap[section.id] ?? '•'}</span>
        </button>
        <div id={`${section.id}-panel`} class="side-dialog right-dialog" hidden>
          <h4>{section.data.title}</h4>
          <p>{section.data.summary}</p>
          {section.data.details.map((item) => (
            <div>
              <h4>{item.heading}</h4>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<script type="module">
  const root = document.currentScript?.previousElementSibling?.closest('.interactive-island');
  if (root) {
    const buttons = root.querySelectorAll('button[data-section]');
    const samImage = root.querySelector('.sam-gif');
    buttons.forEach((button) => {
      const panel = root.querySelector(`#${button.getAttribute('aria-controls')}`);
      button.addEventListener('click', () => {
        const isOpen = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!isOpen));
        if (panel) {
          panel.hidden = isOpen;
        }

        if (samImage) {
          const sectionId = button.getAttribute('data-section');
          samImage.src = sectionId === 'bts' ? '/SAM2.gif' : '/SAM1.gif';
        }
      });
    });
  }
</script>
