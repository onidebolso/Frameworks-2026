---
import { getCollection } from 'astro:content';
import SearchBar from './SearchBar.astro';

const posts = await getCollection('wiki');
---

<aside style="width: 280px; background: var(--ds-bg-secondary); padding: 1rem; height: 100vh; overflow-y: auto; border-right: 1px solid var(--ds-border); box-shadow: inset 0 0 10px rgba(0,0,0,0.5);">
  <h2 class="text-lg font-semibold mb-4" style="color: var(--ds-accent);">Índice da Wiki</h2>
  <SearchBar posts={posts} />
  <ul class="space-y-2">
    {posts.map(post => (
      <li>
        <a href={`/wiki/${Array.isArray(post.slug) ? post.slug.join('/') : post.slug}`} style="color: var(--ds-accent);" class="hover:underline">
          {post.data.title}
        </a>
      </li>
    ))}
  </ul>
</aside>