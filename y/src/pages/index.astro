---
import Layout from '../layouts/Layout.astro';
import MessageCanvas from '../components/MessageCanvas.jsx';
import ExpandableIsland from '../components/ExpandableIsland.jsx';
import { getCollection } from 'astro:content';
import { getOrderedWikiSections } from '../lib/wikiSections.js';

const wikiItems = await getCollection('wiki');
const sections = getOrderedWikiSections(wikiItems);
---

<Layout>
  <main>
    <h1>Death Stranding</h1>
    <ExpandableIsland sections={sections} client:load />

    <div class="floating-island">
      <button class="info-button" title="Informações">
        <span class="icon">ℹ</span>
      </button>
      <div class="dialog-box">
        <p>Bem-vindo Death Stranding.</p>
      </div>
    </div>

    <MessageCanvas client:load />
  </main>
</Layout>