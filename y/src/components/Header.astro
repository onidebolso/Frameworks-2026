---
const { title } = Astro.props;
---

<header style="background: linear-gradient(90deg, var(--ds-bg-secondary) 0%, #232526 100%); color: var(--ds-text); padding: 1rem; border-bottom: 2px solid var(--ds-accent); box-shadow: 0 0 10px var(--ds-shadow);">
  <div class="container mx-auto flex justify-between items-center">
    <h1 class="text-2xl font-bold" style="color: var(--ds-accent);">Death Stranding Wiki</h1>
    <nav>
      <a href="/" class="mr-4 hover:underline" style="color: var(--ds-accent);">Início</a>
      <a href="/wiki/introducao-death-stranding" class="hover:underline" style="color: var(--ds-accent);">Sobre</a>
    </nav>
  </div>
</header>